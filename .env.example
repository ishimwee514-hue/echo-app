# Sanity CMS Configuration
# Get these values from your Sanity project settings at https://manage.sanity.io

# Your Sanity project ID (public, safe to commit in .env.example)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id-here

# Your Sanity dataset name (usually "production" or "development")
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version (format: YYYY-MM-DD)
# Should match the version in your package.json
NEXT_PUBLIC_SANITY_API_VERSION=2023-05-03

# Optional: Sanity authentication token for Studio
# Leave empty for public read-only access
SANITY_STUDIO_TOKEN=

# Optional: Environment for Next.js
NODE_ENV=production